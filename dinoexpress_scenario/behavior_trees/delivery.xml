<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="3">

  <BehaviorTree ID="MainTree">
    <Sequence>
      <NavigateToPose goal="{start_goal}"
                      behavior_tree=""/>
      <Fallback>
        <IsBatteryCharging battery_topic="/boolen"/>
        <ForceFailure>
          <NavigateToPose goal="{initial_goal}"
                          behavior_tree=""/>
        </ForceFailure>
      </Fallback>
      <NavigateToPose goal="{end_goal}"
                      behavior_tree=""/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="IsBatteryCharging">
      <input_port name="battery_topic">Topic for battery info</input_port>
    </Condition>
    <Action ID="NavigateToPose">
      <input_port name="goal">Goal</input_port>
      <input_port name="behavior_tree">Behavior tree to run</input_port>
    </Action>
  </TreeNodesModel>

</root>
